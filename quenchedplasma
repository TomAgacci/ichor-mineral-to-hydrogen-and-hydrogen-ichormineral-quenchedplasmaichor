# ============================================================
# NON-FICTION: HYDROGEN PLASMA → QUENCHED → PRESSURIZED FLUID
# Uses real chemistry (steam reforming), real plasma physics,
# real quenching, and real hydrogen dissolution.
# ============================================================

# ------------------------------------------------------------
# 0. REAL CHEMISTRY BACKBONE (unchanged)
# ------------------------------------------------------------
# Steam reforming:
#   CH4 + H2O → CO + 3 H2
# Water–gas shift:
#   CO + H2O → CO2 + H2
# Overall:
#   CH4 + 2 H2O → CO2 + 4 H2

k_yield = 4.0  # mol H2 per mol CH4

def hydrogen_yield(n_CH4, n_H2O):
    limiting = min(n_CH4, n_H2O / 2.0)
    return k_yield * limiting


# ------------------------------------------------------------
# 1. REAL PLASMA GENERATION (non-fiction)
# ------------------------------------------------------------
# Hydrogen becomes plasma when heated to ~10,000 K or subjected
# to strong electromagnetic fields. We model the thermal route.

T_plasma_threshold = 10000.0  # K (realistic for H2 ionization)

def make_plasma(n_H2, T):
    if T >= T_plasma_threshold:
        return {
            "state": "plasma",
            "H_plus": n_H2,   # symbolic count of ionized units
            "electrons": n_H2
        }
    else:
        return {
            "state": "neutral",
            "H2": n_H2
        }


# ------------------------------------------------------------
# 2. REAL QUENCHING (non-fiction)
# ------------------------------------------------------------
# Plasma hydrogen recombines into neutral H2 when rapidly cooled.

def quench_plasma(plasma_packet, T_quench):
    if plasma_packet["state"] == "plasma" and T_quench < 5000.0:
        # recombination into neutral H2
        return {
            "state": "neutral",
            "H2": plasma_packet["H_plus"]
        }
    else:
        return plasma_packet


# ------------------------------------------------------------
# 3. REAL HYDROGEN DISSOLUTION INTO WATER (non-fiction)
# ------------------------------------------------------------
# Hydrogen dissolves into water under pressure (Henry’s law).

def dissolve_hydrogen(H2_mol, P_bar, V_L):
    k_Henry = 0.02  # symbolic dissolution constant
    dissolved = k_Henry * P_bar * H2_mol / V_L
    return {
        "H2_dissolved_mol": dissolved,
        "fluid_state": "pressurized hydrogen-rich fluid"
    }


# ------------------------------------------------------------
# 4. FULL NON-FICTION PIPELINE
# ------------------------------------------------------------
def make_hydrogen_fluid(n_H2O, n_CH4, V_L, T_reform, T_plasma, T_quench):
    # Step 1: hydrogen production
    n_H2 = hydrogen_yield(n_CH4, n_H2O)

    # Step 2: plasma formation
    plasma_packet = make_plasma(n_H2, T_plasma)

    # Step 3: quenching
    quenched = quench_plasma(plasma_packet, T_quench)

    # Step 4: pressure estimate (ideal gas)
    R = 0.08314
    P_est = (quenched.get("H2", 0) * R * T_quench) / V_L

    # Step 5: dissolution into water
    fluid = dissolve_hydrogen(
        quenched.get("H2", 0),
        P_est,
        V_L
    )

    return {
        "H2_produced": n_H2,
        "plasma_state": plasma_packet["state"],
        "quenched_state": quenched["state"],
        "pressure_bar": P_est,
        "H2_dissolved_mol": fluid["H2_dissolved_mol"],
        "final_state": fluid["fluid_state"]
    }


# ------------------------------------------------------------
# 5. EXAMPLE RUN (non-fiction)
# ------------------------------------------------------------
result = make_hydrogen_fluid(
    n_H2O    = 6.0,
    n_CH4    = 1.5,
    V_L      = 10.0,
    T_reform = 1000.0,   # real reforming temperature
    T_plasma = 12000.0,  # real plasma threshold
    T_quench = 800.0     # real quench temperature
)

